{{- define "main" }}
  {{- $pages := where site.RegularPages "Type" "in" site.Params.mainSections }}
  {{- if site.Params.homeInfoParams }}
  <article class="first-entry home-info">
    <header class="entry-header">
      <h1>{{ site.Params.homeInfoParams.Title | markdownify }}</h1>
    </header>
    <section class="entry-content">
      {{- site.Params.homeInfoParams.Content | markdownify }}
    </section>
    <div class="home-social-links">
      {{- range site.Params.socialIcons }}
      <a href="{{ .url | safeURL }}" target="_blank" rel="noopener noreferrer" class="social-btn social-btn--{{ .name }}" title="{{ .name | title }}">
        {{- partial "svg_icons.html" . -}}
        <span>{{ .name | title }}</span>
      </a>
      {{- end }}
    </div>
  </article>
  {{- end }}
  <div class="posts-container">
    {{- range $pages }}
    <article class="post-entry">
      <header class="entry-header">
        <h2><a href="{{ .Permalink }}">{{ .Title }}</a></h2>
      </header>
      {{- with .Description }}
      <section class="entry-content"><p>{{ . }}</p></section>
      {{- end }}
      <footer class="entry-footer">
        <span>{{ .Date.Format "January 2, 2006" }}</span>
        <span>&middot;</span>
        <span>{{ .ReadingTime }} min</span>
        {{- with .Params.tags }}
        <span>&middot;</span>
        {{- range first 3 . }}
        <span class="tag-pill">{{ . }}</span>
        {{- end }}
        {{- end }}
      </footer>
    </article>
    {{- end }}
  </div>
{{- end }}
